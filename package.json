{
  "name": "@camera.ui/cli",
  "version": "0.0.55",
  "description": "camera.ui cli",
  "type": "module",
  "bin": {
    "cui": "dist/index.js"
  },
  "types": "./dist/types.d.ts",
  "scripts": {
    "audit": "npm audit fix",
    "build": "rimraf dist && tsc && node ./scripts/chmod.js",
    "format": "prettier --write 'src/' --ignore-unknown --no-error-on-unmatched-pattern",
    "install-updates": "npm i --save",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepublishOnly": "npm i --package-lock-only && npm run lint:fix && npm run format && npm run build",
    "release": "bash scripts/release.sh",
    "test": "vitest run",
    "update:templates": "node scripts/update-templates.mjs",
    "update": "updates --update ./ && npm run update:templates"
  },
  "dependencies": {
    "@camera.ui/sdk": "~0.0.9",
    "@clack/prompts": "^1.6.0",
    "adm-zip": "^0.5.17",
    "commander": "^15.0.0",
    "esbuild": "^0.28.1",
    "fs-extra": "^11.3.5",
    "picocolors": "^1.1.1",
    "semver": "^7.8.5",
    "ts-import": "^5.0.0-beta.1"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/adm-zip": "^0.5.8",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "26.0.1",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.1",
    "rimraf": "^6.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.62.0",
    "updates": "^17.18.1",
    "vitest": "^4.1.9"
  },
  "author": "seydx (https://github.com/cameraui/cli)",
  "bugs": {
    "url": "https://github.com/cameraui/cli/issues"
  },
  "homepage": "https://github.com/cameraui/cli#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cameraui/cli.git"
  },
  "keywords": [
    "camera.ui",
    "cli"
  ]
}
